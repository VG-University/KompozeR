# Shared
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=changeme
JWT_SECRET=changeme
REDIS_URL=redis://redis:6379

# Per-service MongoDB URIs (one DB per service)
AUTH_MONGO_URI=mongodb://root:changeme@mongo-auth:27017/authdb?authSource=admin
CAD_MONGO_URI=mongodb://root:changeme@mongo-cad:27017/caddb?authSource=admin
CART_MONGO_URI=mongodb://root:changeme@mongo-cart:27017/cartdb?authSource=admin
CATALOG_MONGO_URI=mongodb://root:changeme@mongo-catalog:27017/catalogdb?authSource=admin
CHAT_MONGO_URI=mongodb://root:changeme@mongo-chat:27017/chatdb?authSource=admin
NOTIFICATION_MONGO_URI=mongodb://root:changeme@mongo-notification:27017/notificationdb?authSource=admin
REPORTING_MONGO_URI=mongodb://root:changeme@mongo-reporting:27017/reportingdb?authSource=admin

# Service ports
GATEWAY_PORT=3000
AUTH_PORT=3001
CAD_PORT=3002
CART_PORT=3003
CATALOG_PORT=3004
CHAT_PORT=3005
NOTIFICATION_PORT=3006
REPORTING_PORT=3007
