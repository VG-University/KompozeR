# Porta su cui il gateway ascolta (default: 3000)
PORT=3000

# Segreto usato per verificare i JWT firmati dall'authenticationService.
# OBBLIGATORIO — il gateway non si avvia se mancante.
JWT_SECRET=change-me-in-production

# URL dei microservizi downstream.
# In Docker Compose corrispondono ai nomi dei service.
AUTH_SERVICE_URL=http://auth-service:3001
CATALOG_SERVICE_URL=http://catalog-service:3002
CAD_SERVICE_URL=http://cad-service:3003
CART_SERVICE_URL=http://cart-service:3004
ORDER_SERVICE_URL=http://order-service:3008
NOTIFICATION_SERVICE_URL=http://notification-service:3005
CHATBOT_SERVICE_URL=http://chatbot-service:3006
REPORTING_SERVICE_URL=http://reporting-service:3007
